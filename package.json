{
  "name": "@rtcoder/string-to-color",
  "version": "1.1.0",
  "description": "A library to convert any string to hex color",
  "type": "module",
  "main": "./dist/cjs/string-to-color.js",
  "module": "./dist/esm/string-to-color.js",
  "types": "./dist/esm/string-to-color.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/string-to-color.d.ts",
      "import": "./dist/esm/string-to-color.js",
      "require": "./dist/cjs/string-to-color.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "node --test test/*.test.cjs",
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('dist/cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "check": "npm run lint && npm run build && npm test",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.cjs\" \"*.js\" \"*.json\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check",
    "preversion": "npm run check",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "prettier": "^2.4.1",
    "typescript": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtcoder/string-to-color.git"
  },
  "keywords": [
    "color",
    "string",
    "hex",
    "convert"
  ],
  "author": "Dawid Jeż",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/rtcoder/string-to-color/issues"
  },
  "homepage": "https://github.com/rtcoder/string-to-color#readme",
  "files": [
    "dist"
  ]
}
